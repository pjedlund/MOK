  "core/typography": {
    "font": {
      "family": {
        "display": {
          "$value": [
            "iA Writer Quattro"
          ],
          "$type": "fontFamilies",
          "$description": "iA Writer Quattro at 700 for headings and the wordmark. Georgia is the metric-compatible system fallback while the woff2 files load."
        },
        "base": {
          "$value": [
            "iA Writer Quattro"
          ],
          "$type": "fontFamilies",
          "$description": "iA Writer Quattro at 400 for body copy, navigation, and metadata. Same family as display — MOK uses one face for both."
        },
        "mono": {
          "$value": [
            "iA Writer Mono"
          ],
          "$type": "fontFamilies",
          "$description": "iA Writer Mono for code blocks, inline code, labels, and dense metadata."
        }
      },
      "weight": {
        "regular": {
          "$value": 400,
          "$type": "fontWeights"
        },
        "bold": {
          "$value": 700,
          "$type": "fontWeights"
        },
        "extra-bold": {
          "$value": 900,
          "$type": "fontWeights"
        }
      },
      "size": {
        "step-min-2": {
          "$value": "16px",
          "$type": "fontSizes"
        },
        "step-min-1": {
          "$value": "22px",
          "$type": "fontSizes"
        },
        "step-0": {
          "$value": "28px",
          "$type": "fontSizes"
        },
        "step-1": {
          "$value": "35px",
          "$type": "fontSizes"
        },
        "step-2": {
          "$value": "44px",
          "$type": "fontSizes"
        },
        "step-3": {
          "$value": "55px",
          "$type": "fontSizes"
        },
        "step-4": {
          "$value": "68px",
          "$type": "fontSizes"
        },
        "step-5": {
          "$value": "86px",
          "$type": "fontSizes"
        },
        "step-6": {
          "$value": "107px",
          "$type": "fontSizes"
        }
      },
      "lineHeight": {
        "flat": {
          "$value": "1",
          "$type": "number"
        },
        "extrafine": {
          "$value": "1.1",
          "$type": "number"
        },
        "fine": {
          "$value": "1.2",
          "$type": "number"
        },
        "standard": {
          "$value": "1.4",
          "$type": "number"
        },
        "fibonacci": {
          "$value": "1.612",
          "$type": "number"
        }
      }
    },
    "type": {
      "body": {
        "$value": {
          "fontFamily": "{font.family.base}",
          "fontWeight": "{font.weight.regular}",
          "fontSize": "{font.size.step-0}",
          "lineHeight": "{font.lineHeight.standard}"
        },
        "$type": "typography"
      },
      "heading": {
        "1": {
          "$value": {
            "fontFamily": "{font.family.display}",
            "fontWeight": "{font.weight.bold}",
            "fontSize": "{font.size.step-6}",
            "lineHeight": "{font.lineHeight.extrafine}"
          },
          "$type": "typography"
        },
        "2": {
          "$value": {
            "fontFamily": "{font.family.display}",
            "fontWeight": "{font.weight.bold}",
            "fontSize": "{font.size.step-4}",
            "lineHeight": "{font.lineHeight.fine}"
          },
          "$type": "typography"
        },
        "3": {
          "$value": {
            "fontFamily": "{font.family.display}",
            "fontWeight": "{font.weight.bold}",
            "fontSize": "{font.size.step-2}",
            "lineHeight": "{font.lineHeight.fine}"
          },
          "$type": "typography"
        }
      },
      "blockquote": {
        "$value": {
          "fontFamily": "{font.family.base}",
          "fontWeight": "{font.weight.regular}",
          "fontSize": "{font.size.step-2}",
          "lineHeight": "{font.lineHeight.standard}"
